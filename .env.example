# EM Center Web - Environment Variables Template
# Copy this file to .env and fill in real values
# NEVER commit .env to git!

# Database
DB_HOST=172.17.0.1
DB_PORT=9150
DB_NAME=emcenter_db
DB_USER=emcenter_user
DB_PASSWORD=your_db_password_here

# SMTP Email
SMTP_HOST=172.22.0.1
SMTP_PORT=25
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@emcenter.sk

# Application
ADMIN_EMAIL=odbyt@em-1.sk
ESHOP_TOKEN=your_eshop_token_here

# NEX API Integration
NEX_API_BASE=http://172.17.0.1:9110

# Optional: Set to "staging" for staging environment
# ENVIRONMENT=staging
